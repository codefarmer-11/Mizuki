---
import Comment from "@components/comment/index.astro";
import { PageHeader } from "@components/features/page-header";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import { postIdMatchesSection } from "@utils/content-utils";
import { getStudyNotesCategorySlugs } from "@utils/study-notes-utils";
import { url } from "@utils/url-utils";
import { getCollection } from "astro:content";

export const prerender = true;

const title = i18n(I18nKey.studyNotes);
const subtitle = i18n(I18nKey.studyNotesCategoriesSubtitle);
const categorySlugs = getStudyNotesCategorySlugs();

const allPosts = await getCollection("posts", ({ data }) => {
	return import.meta.env.PROD ? data.draft !== true : true;
});

function countPostsInCategory(slug: string): number {
	const prefix = `studyNotes/${slug}`;
	return allPosts.filter((p) => postIdMatchesSection(p.id, prefix)).length;
}
---

<MainGridLayout title={title} description={subtitle}>
	<script>
		import("../scripts/right-sidebar-layout.js");
	</script>

	<div
		class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32"
	>
		<div class="card-base z-10 px-6 sm:px-9 py-6 relative w-full">
			<PageHeader title={title} subtitle={subtitle} />

			{
				categorySlugs.length === 0 ? (
					<p class="mt-6 text-50 leading-relaxed">
						{i18n(I18nKey.studyNotesEmptyFolders)}
					</p>
				) : (
					<div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
						{categorySlugs.map((slug) => {
							const n = countPostsInCategory(slug);
							const href = url(
								`/studyNotes/${encodeURIComponent(slug)}/`,
							);
							return (
								<a
									href={href}
									class="group card-base !flex flex-col px-6 py-6 transition
										hover:bg-[var(--btn-card-bg-hover)] active:bg-[var(--btn-card-bg-active)]"
								>
									<span class="text-lg font-bold text-75 group-hover:text-[var(--primary)] transition-colors">
										{slug}
									</span>
									<span class="mt-2 text-sm text-50">
										{n}{" "}
										{i18n(
											n === 1 ? I18nKey.postCount : I18nKey.postsCount,
										)}
									</span>
								</a>
							);
						})}
					</div>
				)
			}
		</div>
	</div>
	<div class="mt-4">
		<Comment path="/studyNotes/" />
	</div>
</MainGridLayout>
