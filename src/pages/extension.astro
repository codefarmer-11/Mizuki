---
import Comment from "@components/comment/index.astro";
import { PageHeader } from "@components/features/page-header";
import Markdown from "@components/misc/Markdown.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import { url } from "@utils/url-utils";
import { getEntry, render } from "astro:content";

export const prerender = true;

const entry = await getEntry("spec", "extension");
const specRendered = entry ? await render(entry) : null;
const SpecMarkdown = specRendered?.Content;
const title = i18n(I18nKey.extensionComponent);
const intro = i18n(I18nKey.extensionToolsIntro);
const qrHref = url("/extension/qr/");
const blankHref = url("/extension/blank/");
---

<MainGridLayout title={title} description={intro}>
	<script>
		import("../scripts/right-sidebar-layout.js");
	</script>
	<div
		class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32"
	>
		<div class="card-base z-10 px-6 sm:px-9 py-6 relative w-full">
			<PageHeader title={title} subtitle={intro} />
			<Markdown class="mt-2 prose dark:prose-invert max-w-none">
				{
					SpecMarkdown ? (
						<SpecMarkdown />
					) : (
						<p>
							在内容仓库的 <code>spec/</code> 下添加{" "}
							<code>extension.md</code> 后即可显示补充说明。
						</p>
					)
				}
			</Markdown>

			<h2 class="mt-10 text-xl font-bold text-75 border-b border-black/10 dark:border-white/10 pb-2">
				{i18n(I18nKey.extensionToolsListTitle)}
			</h2>
			<div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
				<a
					href={qrHref}
					class="group flex flex-col rounded-[var(--radius-large)] border border-black/10 dark:border-white/10
						bg-[var(--card-bg)] p-6 transition hover:border-[var(--primary)] hover:bg-[var(--btn-card-bg-hover)]"
				>
					<span class="text-lg font-bold text-75 group-hover:text-[var(--primary)] transition-colors">
						{i18n(I18nKey.extensionToolQrTitle)}
					</span>
					<p class="mt-2 flex-1 text-sm text-50 leading-relaxed">
						{i18n(I18nKey.extensionToolQrDesc)}
					</p>
					<span
						class="mt-4 inline-flex self-start text-sm font-medium text-[var(--primary)] group-hover:underline"
					>
						{i18n(I18nKey.extensionToolOpen)} →
					</span>
				</a>
				<a
					href={blankHref}
					class="group flex flex-col rounded-[var(--radius-large)] border border-black/10 dark:border-white/10
						bg-[var(--card-bg)] p-6 transition hover:border-[var(--primary)] hover:bg-[var(--btn-card-bg-hover)]"
				>
					<span class="text-lg font-bold text-75 group-hover:text-[var(--primary)] transition-colors">
						{i18n(I18nKey.extensionToolBlankTitle)}
					</span>
					<p class="mt-2 flex-1 text-sm text-50 leading-relaxed">
						{i18n(I18nKey.extensionToolBlankDesc)}
					</p>
					<span
						class="mt-4 inline-flex self-start text-sm font-medium text-[var(--primary)] group-hover:underline"
					>
						{i18n(I18nKey.extensionToolOpen)} →
					</span>
				</a>
			</div>
		</div>
	</div>
	<div class="mt-4">
		<Comment path="/extension/" />
	</div>
</MainGridLayout>
