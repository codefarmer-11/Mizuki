---
import { Icon } from "astro-icon/components";

import { announcementConfig } from "../../../config";
import I18nKey from "../../../i18n/i18nKey";
import { i18n } from "../../../i18n/translation";
import WidgetLayout from "../common/WidgetLayout.astro";

const config = announcementConfig;

/** 公告内容变更后 dismissId 会变，曾关闭的用户会再次看到新公告 */
function getAnnouncementDismissId(): string {
	if (config.version != null && config.version !== "") {
		return String(config.version);
	}
	const payload = `${config.title ?? ""}\0${config.content}`;
	let hash = 0;
	for (let i = 0; i < payload.length; i++) {
		hash = (Math.imul(31, hash) + payload.charCodeAt(i)) | 0;
	}
	return String(hash >>> 0);
}

const dismissId = getAnnouncementDismissId();

interface Props {
	class?: string;
	style?: string;
}
const className = Astro.props.class;
const style = Astro.props.style;
---

<!-- 组件显示现在由sidebarLayoutConfig统一控制，无需检查config.enable -->
<WidgetLayout
	name={config.title || i18n(I18nKey.announcement)}
	id="announcement"
	class={className}
	style={style}
>
	<div>
		<!-- 公告栏内容 -->
		<div
			class="text-neutral-600 dark:text-neutral-300 leading-relaxed mb-3"
		>
			{config.content}
		</div>

		<!-- 可选链接和关闭按钮 -->
		<div class="flex items-center justify-between gap-3">
			<div>
				{
					config.link && config.link.enable !== false && (
						<a
							href={config.link.url}
							target={config.link.external ? "_blank" : "_self"}
							rel={
								config.link.external
									? "noopener noreferrer"
									: undefined
							}
							class="btn-regular rounded-lg px-3 py-1.5 text-sm font-medium active:scale-95 transition-transform"
						>
							{config.link.text}
						</a>
					)
				}
			</div>

			{
				config.closable && (
					<button
						class="btn-regular rounded-lg h-8 w-8 text-sm hover:bg-red-100 dark:hover:bg-red-900/30 transition-colors"
						onclick="closeAnnouncement()"
						aria-label={i18n(I18nKey.announcementClose)}
					>
						<Icon name="fa7-solid:xmark" class="text-sm" />
					</button>
				)
			}
		</div>
	</div>
</WidgetLayout>

<script
	is:inline
	define:vars={{
		dismissId,
	}}
>
	(function () {
		const STORAGE_KEY = "mizuki:announcement:dismissedId";
		const LEGACY_KEY = "announcementClosed";

		function getAnnouncementWidgets() {
			return document.querySelectorAll(
				'widget-layout[data-id="announcement"]',
			);
		}

		function isDismissed() {
			// 旧键 announcementClosed 会永久隐藏，升级后不再沿用
			if (localStorage.getItem(LEGACY_KEY) === "true") {
				localStorage.removeItem(LEGACY_KEY);
			}
			return localStorage.getItem(STORAGE_KEY) === dismissId;
		}

		function applyAnnouncementVisibility() {
			const hidden = isDismissed();
			getAnnouncementWidgets().forEach((widget) => {
				widget.style.display = hidden ? "none" : "";
			});
		}

		function closeAnnouncement() {
			if (getAnnouncementWidgets().length === 0) {
				return;
			}
			localStorage.setItem(STORAGE_KEY, dismissId);
			localStorage.removeItem(LEGACY_KEY);
			applyAnnouncementVisibility();
		}

		function reopenAnnouncement() {
			localStorage.removeItem(STORAGE_KEY);
			localStorage.removeItem(LEGACY_KEY);
			applyAnnouncementVisibility();
		}

		function initAnnouncementDismiss() {
			applyAnnouncementVisibility();
			window.closeAnnouncement = closeAnnouncement;
			window.reopenAnnouncement = reopenAnnouncement;
		}

		if (document.readyState === "loading") {
			document.addEventListener("DOMContentLoaded", initAnnouncementDismiss, {
				once: true,
			});
		} else {
			initAnnouncementDismiss();
		}

		// 侧栏在 Swup 外持久存在，但 DOM 可能晚于首屏脚本就绪
		if (typeof window !== "undefined" && window.swup) {
			window.swup.hooks.on("page:view", () => {
				applyAnnouncementVisibility();
			});
		}
	})();
</script>
