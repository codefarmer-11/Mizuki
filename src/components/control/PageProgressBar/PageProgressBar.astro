---
import "./page-progress-bar.css";

interface Props {
	enable: boolean;
	height: number;
	duration: number;
}

const { enable, height } = Astro.props;
---

{
	enable && (
		<>
			<div
				id="page-progress-bar"
				style={`--page-progress-bar-height: ${height}px;`}
			/>

			<script>
				import { setupPageProgressBar } from "./page-progress-bar.ts";

				if (window.swup) {
					setupPageProgressBar();
				} else {
					document.addEventListener("swup:enable", setupPageProgressBar, {
						once: true,
					});
				}
			</script>
		</>
	)
}
